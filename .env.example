# App behavior
USE_LLM=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LLM_CONTEXT_CONTENT_CHARS=700
LLM_CONTEXT_ARTICLE_LIMIT=25
MAX_ARTICLE_AGE_DAYS=7
MIN_ARTICLES_AFTER_FRESHNESS_FILTER=10
MAX_ARTICLES_FINAL=20
HTTP_TIMEOUT=15

# PostgreSQL
# For Docker Compose keep POSTGRES_HOST=db
# For local Python outside Docker use POSTGRES_HOST=localhost
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_EXPOSE_PORT=5432
POSTGRES_DB=cocolake
POSTGRES_USER=cocolake
POSTGRES_PASSWORD=change-me

# Optional full override
# DATABASE_URL=postgresql://your_user:your_password@localhost:5432/your_db

# API and frontend
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
